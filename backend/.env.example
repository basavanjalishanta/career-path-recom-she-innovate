# Backend Environment Variables (.env)

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_APP=app.py

# Database
DATABASE_URL=sqlite:///career_recommendation.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/career_db

# JWT Secret (Change this in production!)
JWT_SECRET_KEY=your-super-secret-key-change-in-production-12345

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Server
HOST=0.0.0.0
PORT=5000
